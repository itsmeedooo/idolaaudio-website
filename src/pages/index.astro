import { getCollection } from 'astro:content';

// Safely fetch collections. If they don't exist yet, return empty arrays.
let faqs = [];
let portfolios = [];
try {
  faqs = await getCollection('faq');
} catch (e) {
  // Collection might not exist yet
}
try {
  portfolios = await getCollection('portfolio');
} catch (e) {
  // Collection might not exist yet
}

// Default values if no data yet (for smooth transition)
const displayFaqs = faqs.map(f => ({ slug: f.id, entry: f.data }));

const displayPortfolios = portfolios.map(p => ({ slug: p.id, entry: p.data }));
